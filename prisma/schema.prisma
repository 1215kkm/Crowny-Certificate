generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 사용자 ====================

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  phone          String?
  address        String?
  hashedPassword String?
  role           UserRole  @default(STUDENT)
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  enrollments        Enrollment[]
  examSubmissions    ExamSubmission[]
  payments           Payment[]
  certificateIssues  CertificateIssuance[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== 자격증 종류 ====================

enum CertificateGrade {
  GRADE_3    // 3급 - AI 기초 활용
  GRADE_2    // 2급 - AI UI 제작
  GRADE_1    // 1급 - AI 풀스택 제작
  SPECIAL    // 특급 - AI 문제해결
}

enum ExamFormat {
  MULTIPLE_CHOICE   // 객관식
  PRACTICAL         // 실기
  PROJECT           // 프로젝트 제출
  CHALLENGE         // 과제 해결
}

model CertificateType {
  id           String           @id @default(cuid())
  name         String           // "Crowny AI 활용 자격증 3급"
  grade        CertificateGrade
  description  String           @db.Text
  examFormat   ExamFormat
  price        Int              // 시험 응시료 (원)
  coursePrice  Int              // 강의 수강료 (원)
  certPrice   Int              // 인증서 발급비 (원)
  passingScore Int             // 합격 점수
  duration     Int              // 시험 시간 (분)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  courses     Course[]
  exams       Exam[]
  issuances   CertificateIssuance[]
}

// ==================== 강의 시스템 ====================

model Course {
  id                String   @id @default(cuid())
  title             String
  description       String   @db.Text
  thumbnailUrl      String?
  certificateTypeId String
  totalDuration     Int      @default(0) // 총 강의 시간 (초)
  lessonCount       Int      @default(0)
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  certificateType CertificateType @relation(fields: [certificateTypeId], references: [id])
  lessons         Lesson[]
  enrollments     Enrollment[]
}

model Lesson {
  id          String   @id @default(cuid())
  courseId     String
  title       String
  description String?  @db.Text
  videoUrl    String?
  duration    Int      @default(0) // 영상 길이 (초)
  order       Int
  isFree      Boolean  @default(false) // 무료 미리보기
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgresses LessonProgress[]

  @@index([courseId, order])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId     String
  progress    Float     @default(0) // 진도율 (0~100)
  completedAt DateTime?
  paymentId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])

  lessonProgresses LessonProgress[]

  @@unique([userId, courseId])
}

model LessonProgress {
  id           String    @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean   @default(false)
  watchedSec   Int       @default(0) // 시청 시간 (초)
  completedAt  DateTime?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ==================== 시험 시스템 ====================

model Exam {
  id                String   @id @default(cuid())
  certificateTypeId String
  title             String
  description       String?  @db.Text
  scheduledDate     DateTime?
  registrationStart DateTime?
  registrationEnd   DateTime?
  duration          Int      // 시험 시간 (분)
  questionCount     Int      @default(0)
  maxAttempts       Int      @default(1)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  certificateType CertificateType @relation(fields: [certificateTypeId], references: [id])
  questions       ExamQuestion[]
  submissions     ExamSubmission[]
}

enum QuestionType {
  MULTIPLE_CHOICE // 객관식
  SHORT_ANSWER    // 단답형
  ESSAY           // 서술형
  FILE_UPLOAD     // 파일 업로드 (실기)
}

model ExamQuestion {
  id            String       @id @default(cuid())
  examId        String
  type          QuestionType
  content       String       @db.Text
  options       String[]     // 객관식 선택지
  correctAnswer String?      // 정답 (객관식/단답형)
  points        Int          @default(1)
  order         Int
  explanation   String?      @db.Text // 해설
  createdAt     DateTime     @default(now())

  exam    Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers SubmissionAnswer[]

  @@index([examId, order])
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADING
  GRADED
}

model ExamSubmission {
  id          String           @id @default(cuid())
  userId      String
  examId      String
  status      SubmissionStatus @default(IN_PROGRESS)
  score       Float?
  totalPoints Int?
  passed      Boolean?
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?
  gradedBy    String?          // 채점자 (실기시험)
  paymentId   String?
  feedback    String?          @db.Text

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam    Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers SubmissionAnswer[]

  @@index([userId, examId])
}

model SubmissionAnswer {
  id           String @id @default(cuid())
  submissionId String
  questionId   String
  answer       String @db.Text
  fileUrl      String? // 파일 업로드 답안
  points       Float?  // 채점 점수
  isCorrect    Boolean?

  submission ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   ExamQuestion   @relation(fields: [questionId], references: [id])

  @@unique([submissionId, questionId])
}

// ==================== 결제 시스템 ====================

enum PaymentType {
  COURSE      // 강의 수강
  EXAM        // 시험 응시
  CERTIFICATE // 인증서 발급
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  type            PaymentType
  amount          Int           // 결제 금액 (원)
  method          String?       // 결제 수단
  status          PaymentStatus @default(PENDING)
  pgTransactionId String?       // PG사 거래 ID
  pgProvider      String?       // PG사 이름
  receiptUrl      String?       // 영수증 URL
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  issuances   CertificateIssuance[]
}

// ==================== 인증서 발급 ====================

enum DeliveryMethod {
  EMAIL
  MAIL
  BOTH
}

enum IssuanceStatus {
  PENDING    // 발급 대기
  GENERATING // 생성 중
  ISSUED     // 발급 완료
  MAILING    // 우편 발송 중
  DELIVERED  // 배송 완료
}

model CertificateIssuance {
  id                String          @id @default(cuid())
  userId            String
  certificateTypeId String
  issueNumber       String          @unique // 고유 인증번호
  issuedAt          DateTime?
  deliveryMethod    DeliveryMethod  @default(EMAIL)
  pdfUrl            String?
  mailingAddress    String?
  mailingZipCode    String?
  recipientName     String?
  recipientPhone    String?
  trackingNumber    String?         // 운송장 번호
  status            IssuanceStatus  @default(PENDING)
  paymentId         String?
  qrCodeUrl         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificateType CertificateType @relation(fields: [certificateTypeId], references: [id])
  payment         Payment?        @relation(fields: [paymentId], references: [id])
}
